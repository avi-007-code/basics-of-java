--> Magic Number
import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner obj = new Scanner(System.in);
        if (obj.hasNextInt()) {
            int n = obj.nextInt();
            
            // Keep summing digits until n becomes a single digit
            while (n > 9) {
                int sum = 0;
                // Inner loop extracts digits and sums them
                while (n > 0) {
                    sum += n % 10; // Take the last digit
                    n = n / 10;    // Remove the last digit
                }
                n = sum; // Replace n with the new sum for the next pass
            }
            
            // If the final single digit is 1, it's a magic number
            System.out.println(n == 1);
        }
        obj.close();
    }
}
--> Happy number
import java.util.HashSet;

class Solution {
    public boolean isHappy(int n) {
        HashSet<Integer> seen = new HashSet<>();
        
        while (n != 1 && !seen.contains(n)) {
            seen.add(n);
            n = getNext(n);
        }
        return n == 1;
    }
    
    private int getNext(int n) {
        int totalSum = 0;
        while (n > 0) {
            int digit = n % 10;
            totalSum += digit * digit;
            n /= 10;
        }
        return totalSum;
    }
}
